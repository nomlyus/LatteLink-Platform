# Per-environment compose project name. Set a distinct value for dev vs prod.
COMPOSE_PROJECT_NAME=lattelink-dev

# Public API and dashboard domains served by Caddy
API_DOMAIN=api-dev.example.com
CLIENT_DASHBOARD_DOMAIN=app-dev.example.com
LETSENCRYPT_EMAIL=ops@example.com

# GHCR image prefix and tag to deploy
IMAGE_REGISTRY_PREFIX=ghcr.io/anxiousdaoud/lattelink-platform
IMAGE_TAG=latest

# Runtime secrets and service auth
DATABASE_URL=postgresql://postgres.<project-ref>:replace-me@aws-0-us-east-1.pooler.supabase.com:5432/postgres
# Deployed environments should always point DATABASE_URL at Supabase.
# POSTGRES_PASSWORD is only used when you explicitly start the optional local Postgres profile:
#   docker compose --profile local-db up -d
POSTGRES_PASSWORD=
GATEWAY_INTERNAL_API_TOKEN=replace-me
ORDERS_INTERNAL_API_TOKEN=replace-me
LOYALTY_INTERNAL_API_TOKEN=replace-me
NOTIFICATIONS_INTERNAL_API_TOKEN=replace-me
JWT_SECRET=replace-me-with-a-32-char-secret
NOTIFICATIONS_PROVIDER_MODE=expo
EXPO_PUSH_API_URL=
EXPO_ACCESS_TOKEN=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_ALLOWED_CLIENT_IDS=com.lattelink.rawaq.beta,com.lattelink.rawaq
PAYMENTS_PROVIDER_MODE=simulated
CLOVER_OAUTH_ENVIRONMENT=sandbox
CLOVER_APP_ID=
CLOVER_APP_SECRET=
CLOVER_OAUTH_REDIRECT_URI=
CLOVER_OAUTH_STATE_SECRET=
CLOVER_WEBHOOK_SHARED_SECRET=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_CONNECT_WEBHOOK_SECRET=
CATALOG_MEDIA_R2_ACCOUNT_ID=
CATALOG_MEDIA_R2_ACCESS_KEY_ID=
CATALOG_MEDIA_R2_SECRET_ACCESS_KEY=
CATALOG_MEDIA_R2_BUCKET=
CATALOG_MEDIA_PUBLIC_BASE_URL=
CATALOG_MEDIA_UPLOAD_MAX_BYTES=10485760
CATALOG_MEDIA_UPLOAD_EXPIRY_SECONDS=300

# Gateway runtime
CORS_ALLOWED_ORIGINS=https://app-dev.example.com,https://admin-dev.example.com
PUBLIC_API_BASE_URL=https://api-dev.example.com/v1
GATEWAY_UPSTREAM_TIMEOUT_MS=5000
GATEWAY_RATE_LIMIT_WINDOW_MS=60000

# Passkey RP ID for identity service
PASSKEY_RP_ID=api-dev.example.com
ALLOW_DEV_CUSTOMER_LOGIN=false

# Google SSO for the client dashboard
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_STATE_SECRET=
GOOGLE_OAUTH_ALLOWED_REDIRECT_URIS=

# Optional external menu-sync worker configuration.
# Leave WEBAPP_MENU_SOURCE_URL blank to keep the worker deployed but disabled.
WEBAPP_MENU_SOURCE_URL=
MENU_SYNC_LOCATION_ID=rawaqcoffee01
MENU_SYNC_INTERVAL_MS=300000
MENU_SYNC_MAX_RETRIES=3
MENU_SYNC_RETRY_DELAY_MS=2000
