# Public API domain served by Caddy
API_DOMAIN=api.example.com
LETSENCRYPT_EMAIL=ops@example.com

# GHCR image prefix and tag to deploy
IMAGE_REGISTRY_PREFIX=ghcr.io/anxiousdaoud/lattelink-platform
IMAGE_TAG=latest

# Runtime secrets and service auth
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgresql://gazelle:replace-me@postgres:5432/gazelle
GATEWAY_INTERNAL_API_TOKEN=replace-me
ORDERS_INTERNAL_API_TOKEN=replace-me
LOYALTY_INTERNAL_API_TOKEN=replace-me
NOTIFICATIONS_INTERNAL_API_TOKEN=replace-me
JWT_SECRET=replace-me-with-a-32-char-secret
PAYMENTS_PROVIDER_MODE=simulated

# Gateway runtime
CORS_ALLOWED_ORIGINS=https://client.example.com
PUBLIC_API_BASE_URL=https://api.example.com/v1
GATEWAY_UPSTREAM_TIMEOUT_MS=5000
GATEWAY_RATE_LIMIT_WINDOW_MS=60000

# Passkey RP ID for identity service
PASSKEY_RP_ID=api.example.com

# Google SSO for the client dashboard
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_STATE_SECRET=
GOOGLE_OAUTH_ALLOWED_REDIRECT_URIS=
