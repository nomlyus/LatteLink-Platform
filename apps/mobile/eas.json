{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "beta": {
      "extends": "base",
      "autoIncrement": true,
      "distribution": "store",
      "environment": "preview",
      "channel": "beta",
      "env": {
        "APP_VARIANT": "beta",
        "EXPO_PUBLIC_APP_VARIANT": "beta",
        "IOS_BUNDLE_IDENTIFIER": "com.lattelink.rawaq.beta",
        "EXPO_PUBLIC_IOS_BUNDLE_IDENTIFIER": "com.lattelink.rawaq.beta",
        "APP_DISPLAY_NAME_BASE": "Rawaq",
        "EXPO_PUBLIC_BRAND_NAME": "Rawaq",
        "EXPO_PUBLIC_LOCATION_ID": "rawaqcoffee01",
        "EXPO_PUBLIC_API_BASE_URL": "https://api-dev.nomly.us/v1",
        "EXPO_PUBLIC_CATALOG_SERVICE_BASE_URL": "https://api-dev.nomly.us/v1",
        "EXPO_PUBLIC_CATALOG_API_BASE_URL": "https://api-dev.nomly.us/v1",
        "EXPO_PUBLIC_PRIVACY_POLICY_URL": "https://nomly.us/privacy-policy"
      }
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "distribution": "store",
      "environment": "production",
      "channel": "production",
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_APP_VARIANT": "production",
        "IOS_BUNDLE_IDENTIFIER": "com.lattelink.rawaq",
        "EXPO_PUBLIC_IOS_BUNDLE_IDENTIFIER": "com.lattelink.rawaq",
        "APP_DISPLAY_NAME_BASE": "Rawaq",
        "EXPO_PUBLIC_BRAND_NAME": "Rawaq",
        "EXPO_PUBLIC_LOCATION_ID": "rawaqcoffee01",
        "EXPO_PUBLIC_API_BASE_URL": "https://api.nomly.us/v1",
        "EXPO_PUBLIC_CATALOG_SERVICE_BASE_URL": "https://api.nomly.us/v1",
        "EXPO_PUBLIC_CATALOG_API_BASE_URL": "https://api.nomly.us/v1",
        "EXPO_PUBLIC_APPLE_PAY_MERCHANT_ID": "merchant.com.lattelink.rawaq",
        "EXPO_PUBLIC_PRIVACY_POLICY_URL": "https://nomly.us/privacy-policy"
      }
    }
  },
  "submit": {
    "beta": {
      "ios": {
        "ascAppId": "6761780971"
      }
    },
    "production": {
      "ios": {
        "ascAppId": "6764649231"
      }
    }
  }
}
