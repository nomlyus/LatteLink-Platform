{
  "name": "@lattelink/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "./index.js",
  "scripts": {
    "build:workspace-deps": "cd ../.. && pnpm --filter @lattelink/contracts-core build && pnpm --filter @lattelink/contracts-auth build && pnpm --filter @lattelink/contracts-catalog build && pnpm --filter @lattelink/contracts-orders build && pnpm --filter @lattelink/contracts-loyalty build && pnpm --filter @lattelink/contracts-notifications build && pnpm --filter @lattelink/design-tokens build && pnpm --filter @lattelink/sdk-mobile build",
    "dev": "expo start --clear",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "build": "echo 'Use EAS build for mobile artifacts'",
    "postinstall": "pnpm run build:workspace-deps",
    "release:check": "node scripts/validate-release-env.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint app src test --max-warnings=0",
    "test": "vitest run"
  },
  "dependencies": {
    "@callstack/liquid-glass": "^0.7.0",
    "@devvie/bottom-sheet": "0.4.3",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@lattelink/contracts-catalog": "workspace:*",
    "@lattelink/contracts-orders": "workspace:*",
    "@lattelink/design-tokens": "workspace:*",
    "@lattelink/sdk-mobile": "workspace:*",
    "@react-native-community/datetimepicker": "^8.3.0",
    "@react-native-picker/picker": "^2.9.0",
    "@stripe/stripe-react-native": "^0.50.3",
    "@tanstack/react-query": "^5.66.11",
    "expo": "^54.0.33",
    "expo-apple-authentication": "^8.0.8",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-font": "~14.0.11",
    "expo-glass-effect": "~0.1.8",
    "expo-linear-gradient": "^55.0.13",
    "expo-linking": "~8.0.11",
    "expo-router": "^6.0.23",
    "expo-secure-store": "^15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-updates": "~29.0.16",
    "nativewind": "^4.1.23",
    "react": "19.2.5",
    "react-native": "0.85.2",
    "react-native-css-interop": "^0.2.3",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-reanimated": "~4.3.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-worklets": "0.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@expo/ngrok": "^4.1.0",
    "@lattelink/config-eslint": "workspace:*",
    "@types/react": "^19.2.14",
    "babel-preset-expo": "^54.0.10",
    "eslint": "^9.21.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
