{
  "name": "@gazelle/identity",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src test --max-warnings=0",
    "test": "vitest run",
    "openapi": "tsx src/openapi.ts"
  },
  "dependencies": {
    "@fastify/rate-limit": "^9.1.0",
    "@gazelle/contracts-auth": "workspace:*",
    "@gazelle/contracts-core": "workspace:*",
    "@gazelle/persistence": "workspace:*",
    "@simplewebauthn/server": "^13.2.2",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^3.1.0",
    "fastify": "^5.8.3",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@gazelle/config-eslint": "workspace:*",
    "@gazelle/config-typescript": "workspace:*",
    "@types/node": "^22.13.8",
    "eslint": "^9.21.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
