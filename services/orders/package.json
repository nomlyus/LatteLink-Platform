{
  "name": "@lattelink/orders",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src test --max-warnings=0",
    "test": "vitest run",
    "openapi": "tsx src/openapi.ts"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "@lattelink/contracts-catalog": "workspace:*",
    "@lattelink/event-bus": "workspace:*",
    "@lattelink/observability": "workspace:*",
    "ioredis": "^5.6.1",
    "@lattelink/persistence": "workspace:*",
    "@lattelink/contracts-orders": "workspace:*",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "fastify": "^5.8.4",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@lattelink/config-eslint": "workspace:*",
    "@lattelink/config-typescript": "workspace:*",
    "@types/node": "^22.13.8",
    "eslint": "^9.21.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
