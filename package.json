{
  "name": "gazelle-mobile-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Gazelle mobile ordering platform monorepo",
  "license": "MIT",
  "packageManager": "pnpm@10.5.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "build": "turbo run build",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "dev": "turbo run dev --parallel",
    "dev:services": "./scripts/dev-local-services.sh",
    "dev:services:lan": "./scripts/dev-local-services-lan.sh",
    "dev:mobile:local": "EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8080/v1 pnpm --filter @gazelle/mobile dev",
    "dev:mobile:lan": "./scripts/dev-mobile-lan.sh",
    "dev:worker:menu-sync": "pnpm --filter @gazelle/menu-sync-worker dev",
    "dev:worker:notifications-dispatch": "pnpm --filter @gazelle/notifications-dispatch-worker dev",
    "contracts:openapi": "turbo run openapi --filter=@gazelle/gateway --filter=@gazelle/contracts-*",
    "contracts:drift": "./scripts/verify-contract-drift.sh",
    "sdk:generate": "pnpm --filter @gazelle/sdk-mobile generate",
    "terraform:fmt": "terraform -chdir=infra/terraform/envs/dev fmt -recursive -check",
    "terraform:validate": "pnpm -r --filter ./infra/terraform/envs/* run validate"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.8",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
