EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8080/v1
DATABASE_URL='postgresql://postgres.[project-ref]:[password]@[host]:5432/postgres?sslmode=require'
ALLOW_IN_MEMORY_PERSISTENCE=
# Run migrations manually: pnpm --filter @lattelink/persistence migrate
CATALOG_SERVICE_BASE_URL=http://127.0.0.1:3002
GATEWAY_INTERNAL_API_TOKEN=
LOYALTY_INTERNAL_API_TOKEN=
NOTIFICATIONS_INTERNAL_API_TOKEN=
GATEWAY_UPSTREAM_TIMEOUT_MS=5000
GATEWAY_RATE_LIMIT_WINDOW_MS=60000
GATEWAY_RATE_LIMIT_AUTH_WRITE_MAX=24
GATEWAY_RATE_LIMIT_AUTH_READ_MAX=120
GATEWAY_RATE_LIMIT_CATALOG_READ_MAX=180
GATEWAY_RATE_LIMIT_ORDERS_READ_MAX=120
GATEWAY_RATE_LIMIT_ORDERS_WRITE_MAX=60
GATEWAY_RATE_LIMIT_CHECKOUT_MAX=20
GATEWAY_RATE_LIMIT_LOYALTY_READ_MAX=120
GATEWAY_RATE_LIMIT_PUSH_TOKEN_MAX=30
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME=Gazelle
PASSKEY_EXPECTED_ORIGINS=https://localhost
PASSKEY_TIMEOUT_MS=60000
# Set the same JWT_SECRET on identity and gateway to enable locally verified JWT access tokens.
# Use at least 32 characters. Example: openssl rand -base64 48
# When unset, access tokens fall back to the legacy opaque-token path.
JWT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CLIENT_ID=
APPLE_ALLOWED_CLIENT_IDS=
IDENTITY_RATE_LIMIT_WINDOW_MS=60000
IDENTITY_RATE_LIMIT_AUTH_WRITE_MAX=24
IDENTITY_RATE_LIMIT_AUTH_READ_MAX=120
IDENTITY_RATE_LIMIT_PASSKEY_CHALLENGE_MAX=24
IDENTITY_RATE_LIMIT_PASSKEY_VERIFY_MAX=12
MAIL_PROVIDER=log
RESEND_API_KEY=
MAGIC_LINK_BASE_URL=http://localhost:8080
MAGIC_LINK_EXPIRY_MINUTES=15
# Google OAuth for client dashboard operator sign-in.
# Keep the redirect URI list exact and comma-separated.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_STATE_SECRET=
GOOGLE_OAUTH_ALLOWED_REDIRECT_URIS=http://127.0.0.1:4173/?google_auth_callback=1
# Clover live/sandbox mode:
# - leave PAYMENTS_PROVIDER_MODE=simulated for normal local development
# - switch to live only when Clover OAuth is configured and merchants connect through the OAuth flow
PAYMENTS_PROVIDER_MODE=simulated
CLOVER_OAUTH_ENVIRONMENT=sandbox
CLOVER_APP_ID=
CLOVER_APP_SECRET=
CLOVER_OAUTH_REDIRECT_URI=
CLOVER_OAUTH_STATE_SECRET=
CLOVER_WEBHOOK_SHARED_SECRET=
ORDERS_SERVICE_BASE_URL=http://127.0.0.1:3001
ORDERS_INTERNAL_API_TOKEN=
